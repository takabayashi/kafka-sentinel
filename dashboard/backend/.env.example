KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092

# Kafka Cluster API Keys (for producing/consuming)
KAFKA_API_KEY=your-kafka-api-key
KAFKA_API_SECRET=your-kafka-api-secret

# Confluent Cloud API Keys (for Metrics API)
# Create at: https://confluent.cloud/settings/api-keys
CONFLUENT_CLOUD_API_KEY=your-cloud-api-key
CONFLUENT_CLOUD_API_SECRET=your-cloud-api-secret

WEBSOCKET_PORT=8080
