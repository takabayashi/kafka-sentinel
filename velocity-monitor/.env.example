# Kafka API Credentials (for REST API v3 calls + publishing metrics)
# Get these from: Confluent Cloud Console > Cluster > API Keys
# REST API v3 (Consumer Group API) uses the SAME Kafka cluster credentials
KAFKA_API_KEY=your-kafka-api-key
KAFKA_API_SECRET=your-kafka-api-secret

# Velocity Monitor Configuration
POLL_INTERVAL_SECONDS=10
